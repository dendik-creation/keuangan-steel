<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aplikasi Manajemen Keuangan Pribadi</title>
  <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
  <%- include('partials/navbar-auth', { active: '' }) %>

  <main class="container auth-grid">
    <section class="auth-hero">
      <div class="hero-label">Keuangan</div>
      <p class="eyebrow">Aplikasi fintech pribadi</p>
      <h1>Atur pengeluaran dan rencanakan masa depan dengan tampilan modern.</h1>
      <p class="hero-text">Dapatkan gambaran cepat tentang saldo, transaksi, dan laporan tanpa harus berpindah menu.</p>
      <div class="hero-actions">
        <a href="/login" class="btn btn-primary">Login</a>
        <a href="/register" class="btn btn-secondary">Daftar Gratis</a>
      </div>
      <div class="hero-highlights">
        <div class="highlight-card">
          <strong>+250%</strong>
          <span>Kecepatan pencatatan</span>
        </div>
        <div class="highlight-card">
          <strong>4 fitur</strong>
          <span>Laporan, dashboard, transaksi, dan ringkasan</span>
        </div>
      </div>
    </section>

  
    <section class="home-features">
      <div class="section-header">
        <span class="eyebrow">Keunggulan</span>
        <h2>Kelola keuangan tanpa kompromi.</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-card feature-card-highlight">
          <h3>Kontrol penuh</h3>
          <p>Catat pemasukan dan pengeluaran dengan bebas, lalu pantau hasilnya secara instan.</p>
        </div>
        <div class="feature-card">
          <h3>Data jelas</h3>
          <p>Ringkasan visual membantu Anda mengambil keputusan dengan cepat.</p>
        </div>
        <div class="feature-card">
          <h3>Tersedia kapan saja</h3>
          <p>Akses dasbor dari browser dengan pengalaman mobile-friendly.</p>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Redirect to dashboard if already logged in
    fetch('/api/auth/user')
      .then(response => {
        if (response.ok) {
          window.location.href = '/dashboard';
        }
      })
      .catch(err => console.log('User tidak login'));
  </script>
</body>
</html>

