<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kelola Transaksi - Aplikasi Manajemen Keuangan</title>
  <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
  <%- include('partials/navbar', { active: 'transaksi' }) %>

  <main class="container transaksi-container">
    <div class="dashboard-header">
      <div>
        <h2 class="page-title">Kelola Transaksi</h2>
        <p class="page-subtitle">Tambahkan atau perbarui pemasukan dan pengeluaran dengan mudah.</p>
      </div>
      <div class="dashboard-actions">
        <button type="button" class="btn btn-secondary" id="clear-form-btn">Bersihkan Form</button>
      </div>
    </div>

    <div class="form-section">
      <h3 id="form-title">Tambah Transaksi</h3>
      <form id="form-transaksi" action="/transaksi" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="jenis">Jenis:</label>
            <select id="jenis" name="jenis" required>
              <option value="">Pilih Jenis</option>
              <option value="Pemasukan">Pemasukan</option>
              <option value="Pengeluaran">Pengeluaran</option>
            </select>
          </div>
          <div class="form-group">
            <label for="tanggal">Tanggal:</label>
            <input type="date" id="tanggal" name="tanggal" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="keterangan">Keterangan:</label>
            <input type="text" id="keterangan" name="deskripsi" placeholder="Masukkan keterangan" required>
          </div>
          <div class="form-group">
            <label for="jumlah">Jumlah:</label>
            <input type="number" id="jumlah" name="jumlah" placeholder="Masukkan jumlah" min="1" required>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Simpan</button>
          <button type="reset" class="btn btn-secondary">Reset</button>
        </div>
        <div id="form-message" class="form-message"></div>
      </form>
    </div>

    <div class="filter-section">
      <h3>Temukan Transaksi</h3>
      <input type="text" id="cari" placeholder="Cari transaksi...">
      <button type="button" class="btn btn-primary" id="btn-cari">Cari</button>
    </div>

    <div class="transactions-section">
      <h3>Daftar Transaksi</h3>
      <table id="tabel-transaksi">
        <thead>
          <tr>
            <th>No</th>
            <th>Tanggal</th>
            <th>Keterangan</th>
            <th>Jenis</th>
            <th>Jumlah</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof transaksi !== 'undefined' && transaksi.length > 0) { %>
            <% transaksi.forEach((t, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= t.tanggal %></td>
                <td><%= t.deskripsi %></td>
                <td><%= t.jenis %></td>
                <td>Rp <%= t.jumlah.toLocaleString('id-ID') %></td>
                <td>
                  <form action="/transaksi/hapus/<%= t.id %>" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger" style="background-color: red; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">Hapus</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" style="text-align: center; padding: 20px;">Belum ada data transaksi.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/scripts/auth.js"></script>
  <script src="/scripts/transaksi.js"></script>
</body>
</html>

